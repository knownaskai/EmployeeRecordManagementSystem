# ═══════════════════════════════════════════════════════════════
# .gitignore — Employee Record Management System
# ═══════════════════════════════════════════════════════════════

# ── SECURITY: Never commit secrets ───────────────────────────
.env
*.env
secrets.properties

# ── Maven build output ────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear

# ── IDE files ─────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.code-workspace
.project
.classpath
.settings/
*.factorypath
nbproject/
nb-configuration.xml

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── Runtime ───────────────────────────────────────────────────
*.pid
